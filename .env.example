# CB Workspace (CLI / quick_start may use CB_*; web UI uses CREATEBYTES_*)
CB_WORKSPACE_EMAIL=your-email@example.com
CB_WORKSPACE_PASSWORD=your-password
CREATEBYTES_EMAIL=your-email@example.com
CREATEBYTES_PASSWORD=your-password

# CB Workspace Configuration
CB_WORKSPACE_URL=https://cb.workspace.createbytes.com
CREATEBYTES_WORKSPACE_URL=https://cb.workspace.createbytes.com
CB_PROJECT_ID=your-cb-project-uuid
CREATEBYTES_PROJECT_ID=your-cb-project-uuid

# Jira Configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_PROJECT_KEY=YOUR_JIRA_PROJECT_KEY
JIRA_BOARD_ID=your-numeric-board-id

# Optional: Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SLOW_MO=0
